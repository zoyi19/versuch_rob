; 手臂轨迹插补限制（仅用于上层 armTrajInterpFilter），与 optimizedTrajKinematicLimit 解耦
armTrajInterpKinematicLimit
{
  enable                         true  ; false: 保持旧版逻辑, true: 启用手臂轨迹插补增强路径
  history_size                   3      ; [sample], min=2
  reference_update_period        0.010  ; [s], should match arm trajectory source period
  q_cutoff_hz                    30.0
  v_cutoff_hz                    15.0
  a_cutoff_hz                    120.0
  ; dq output remap per joint: x=|dq_lp_i|, scale_i = atan(dq_remap_k_i*(x-dq_remap_offset_i))/(1.57*2)+0.5, out_i = scale_i * dq_lp_i
  dq_remap_k
  {
    (0,0)   6.0  ; z_arm_l1
    (1,0)   6.0  ; z_arm_l2
    (2,0)   6.0  ; z_arm_l3
    (3,0)   6.0  ; z_arm_l4
    (4,0)   16.0  ; z_arm_l5
    (5,0)   16.0  ; z_arm_l6
    (6,0)   16.0  ; z_arm_l7
    (7,0)   6.0  ; z_arm_r1
    (8,0)   6.0  ; z_arm_r2
    (9,0)   6.0  ; z_arm_r3
    (10,0)  6.0  ; z_arm_r4
    (11,0)  16.0  ; z_arm_r5
    (12,0)  16.0  ; z_arm_r6
    (13,0)  16.0  ; z_arm_r7
  }

  dq_remap_offset
  {
    (0,0)   0.5  ; z_arm_l1
    (1,0)   0.5  ; z_arm_l2
    (2,0)   0.5  ; z_arm_l3
    (3,0)   0.5  ; z_arm_l4
    (4,0)   0.2  ; z_arm_l6
    (6,0)   0.2  ; z_arm_l7
    (7,0)   0.5  ; z_arm_r1
    (8,0)   0.5  ; z_arm_r2
    (9,0)   0.5  ; z_arm_r3
    (10,0)  0.5  ; z_arm_r4
    (11,0)  0.2  ; z_arm_r5
    (12,0)  0.2  ; z_arm_r6
    (13,0)  0.2  ; z_arm_r7
  }

  ; fhan 跟踪微分器参数（动力学约束 q/dq 平滑层）
  ; fhan_r: 等效加速度阈值 [rad/s^2]，越大跟踪越快但响应越硬
  ; fhan_h0_ratio: h0 = ratio * controlCycleSec，建议 2~5
  fhan_r                         5000.0
  fhan_h0_ratio                  5.0
}


