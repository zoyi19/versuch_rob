<launch>
  <arg name="robot_version"      default="$(optenv ROBOT_VERSION 45)"/>
  <param name="robot_version"    value="$(arg robot_version)"/>
  <arg name="use_xacro" value="$(eval int(arg('robot_version')) >= 40)"/>

  <!-- robot_type: 1=轮臂, 2=双足
       版本号规则: major=(version%100)/10, minor=version%10
       判断方法: major==6 为轮臂，即 version%100 在[60,70)范围
       例如: 45(major=4)->双足, 60(major=6)->轮臂, 100045(major=4)->双足, 100060(major=6)->轮臂 -->
    <arg name="robot_type"
         default="$(eval '1' if 60 &lt;= int(arg('robot_version')) % 100 &lt; 70 else '2')"/>
    <param name="robot_type" value="$(arg robot_type)"/>

  <arg name="use_grab_box_scene" default="false"/>
  <arg name="use_grab_box_new_scene" default="false"/>
  <arg name="world_name"  default="$(find gazebo_ros)/worlds/empty.world"/>
  <arg name="use_kuavo" value="$(eval int(arg('robot_version')) >= 40)"/>
  <arg name="spawn_z"        default="$(eval '1.0' if int(arg('robot_type')) == 2 else '0.0')"/>

  <!-- 楼梯参数（用于传递给load_stairs.launch） -->
  <!-- 第一段楼梯（上楼梯）参数 -->
  <arg name="use_stairs" default="false" doc="是否添加楼梯到场景中"/>
  <arg name="use_slope" default="false" doc="是否添加斜坡到场景中"/>
  <arg name="stairs_model_path" default="$(find gazebo_sim)/models/stairs/stairs_generated.sdf" doc="楼梯模型SDF文件路径"/>
  <arg name="stairs_x" default="1.5" doc="楼梯位置X坐标"/>
  <arg name="stairs_y" default="0.0" doc="楼梯位置Y坐标"/>
  <arg name="stairs_z" default="0.0" doc="楼梯位置Z坐标"/>
  <arg name="stairs_roll" default="0.0" doc="楼梯绕X轴旋转角度（弧度）"/>
  <arg name="stairs_pitch" default="0.0" doc="楼梯绕Y轴旋转角度（弧度）"/>
  <arg name="stairs_yaw" default="0.0" doc="楼梯绕Z轴旋转角度（弧度）"/>
  
  <!-- 第二段楼梯（下楼梯）参数 -->
  <arg name="stairs2_model_path" default="$(find gazebo_sim)/models/stairs/wood_stairs.sdf" doc="第二段楼梯模型SDF文件路径，默认使用木质楼梯"/>
  <arg name="num_steps" default="5" doc="楼梯的台阶数量（用于计算拼接位置）"/>
  <arg name="step_depth" default="0.3" doc="楼梯台阶深度（用于计算拼接位置）"/>
  <arg name="step_height" default="0.2" doc="楼梯台阶高度（用于计算拼接位置）"/>
  
  <!-- Start Gazebo -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_name)"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="false"/>
  </include>

  <group if="$(arg use_stairs)">
    <group if="$(arg use_kuavo)">
      <!-- 加载楼梯模型 -->
      <include file="$(find gazebo_sim)/launch/load_stairs.launch">
      </include>
    </group>
    <group unless="$(arg use_kuavo)">
      <!-- 加载楼梯模型 -->
      <include file="$(find gazebo_sim)/launch/load_stairs_roban.launch">
      </include>
        <!-- 加载斜坡模型 -->
    <include file="$(find gazebo_sim)/launch/load_slope_roban.launch">
    </include>
    </group>
  </group>

    <group if="$(arg use_slope)">
      <!-- 加载斜坡模型 -->
      <include file="$(find gazebo_sim)/launch/load_slope_roban.launch">
    </include>
  </group>

  <!-- Load URDF or XACRO file based on model version -->
  <group if="$(arg use_xacro)">
    <!-- 根据robot_version加载对应模型 -->
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/biped_s$(arg robot_version)/urdf/biped_s$(arg robot_version)_gazebo.xacro"/>
    <!-- static tf transform -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="camera_to_robot_frame" args="0 0 0 0 0 0 camera_base camera_base_link" />
    <!-- camera meta data And Gobal tf transform -->
    <include file="$(find realsense_sim_metadata)/launch/metadata_start.launch">
      <arg name="camera_name" value="camera"/>
      <arg name="use_nvblox" value="false"/>
      <arg name="use_tf" value="true"/>
    </include>
  </group>

  <group unless="$(arg use_xacro)">
    <!-- For versions 30, 31 32 -->
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/biped_s$(arg robot_version)/urdf/biped_s$(arg robot_version)_gazebo.urdf"/>
  </group>

  <!-- Spawn URDF model into Gazebo -->
  <node name="spawn_robot" pkg="gazebo_ros" type="spawn_model" 
        args="-urdf -model biped_s$(arg robot_version) -param robot_description -x 0 -y 0 -z $(arg spawn_z)"/>

  <group if="$(arg use_grab_box_new_scene)">
    <param name="table_apriltag_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/apriltag/urdf/grab_box_table_new.xacro"/>

    <!-- 生成table_apriltag模型 -->
    <node name="spawn_table_apriltag" pkg="gazebo_ros" type="spawn_model" 
          args="-urdf -model table_apriltag -param table_apriltag_description -x 0.0 -y 0.0 -z 0.0"/>

    <!-- 加载block -->
    <param name="block_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/apriltag/urdf/block.urdf.xacro"/>
    <!-- 生成block模型，使用floating joint -->
    <node name="spawn_block" pkg="gazebo_ros" type="spawn_model" 
          args="-urdf -model block -param block_description -x 1.5 -y -0.7 -z 2.0 -R 0 -P 0 -Y 0"
          launch-prefix="bash -c 'sleep 1.5; $0 $@' "/>     
  </group>
  <group unless="$(arg use_grab_box_new_scene)">
    <group unless="$(arg use_grab_box_scene)">
      <!-- 加载独立的 AprilTag Cube -->
      <param name="apriltag_cube_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/apriltag/urdf/standalone_cube.xacro"/>
      <!-- 生成 AprilTag Cube 模型 -->
      <node name="spawn_apriltag_cube" pkg="gazebo_ros" type="spawn_model" 
            args="-urdf -model apriltag_cube -param apriltag_cube_description"/>
      <!-- 加载block -->
      <param name="block_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/apriltag/urdf/block.urdf.xacro"/>
      <!-- 生成block模型，使用floating joint -->
      <node name="spawn_block" pkg="gazebo_ros" type="spawn_model" 
            args="-urdf -model block -param block_description -x 0.0 -y -1.0 -z 2.0 -R 0 -P 0 -Y 0"
            launch-prefix="bash -c 'sleep 1.5; $0 $@' "/>
    </group>
    <group if="$(arg use_grab_box_scene)">
      <param name="table_apriltag_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/apriltag/urdf/grab_box_table.xacro"/>

      <!-- 生成table_apriltag模型 -->
      <node name="spawn_table_apriltag" pkg="gazebo_ros" type="spawn_model" 
            args="-urdf -model table_apriltag -param table_apriltag_description -x 0.0 -y 0.0 -z 0.0"/>

      <!-- 加载block -->
      <param name="block_description" command="$(find xacro)/xacro --inorder $(find kuavo_assets)/models/apriltag/urdf/block.urdf.xacro"/>
      <!-- 生成block模型，使用floating joint -->
      <node name="spawn_block" pkg="gazebo_ros" type="spawn_model" 
            args="-urdf -model block -param block_description -x 0.0 -y -1.9 -z 2.0 -R 0 -P 0 -Y 0"
            launch-prefix="bash -c 'sleep 1.5; $0 $@' "/>      
    </group>
  </group>

  <!-- Start robot state publisher to publish TF -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" value="500.0"/>
  </node>

  <!-- Load controller configuration -->
  <rosparam file="$(find kuavo_assets)/models/biped_s$(arg robot_version)/config/controllers.yaml"/>

  <!-- <rosparam file="$(find gazebo_sim)/launch/defaultQ.yaml" command="load" /> -->

  <!-- Start controller manager -->
  <!-- <node name="controller_manager" pkg="controller_manager" type="controller_manager" respawn="false" output="screen" args="spawn joint_state_controller limbs_effort_controller joint_position_controller"/> -->

  <!-- Start the sensor_data_publisher node to sync IMU and joint states -->
  <!-- <node name="sensor_data_publisher" pkg="gazebo_sim" type="sensor_data_publisher" output="screen"/> -->

  <!-- 使用共享内存通信，不需要ROS话题桥接 -->
</launch>
