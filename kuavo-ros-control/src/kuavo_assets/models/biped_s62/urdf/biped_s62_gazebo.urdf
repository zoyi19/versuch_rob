  <!-- 为4个轮子设置物理参数 -->
  <gazebo reference="LF_wheel_pitch">
    <mu1>0.5</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.0</minDepth>
  </gazebo>

  <gazebo reference="RF_wheel_pitch">
    <mu1>0.5</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.0</minDepth>
  </gazebo>

  <gazebo reference="LB_wheel_pitch">
    <mu1>0.5</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.0</minDepth>
  </gazebo>

  <gazebo reference="RB_wheel_pitch">
    <mu1>0.5</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.0</minDepth>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_shm_interface" filename="libgazebo_sim_shm_interface.so">
      <!-- IMU配置 -->
      <imu>
        <frame_id>base_link</frame_id>
      </imu>
      
      <!-- 关节配置 -->
      <joints>
        <!-- 轮子关节（按照MuJoCo XML的body顺序：轮子在腿部之前） -->
        <!-- <joint><name>wheel_left_front</name></joint>
        <joint><name>wheel_right_front</name></joint>
        <joint><name>wheel_left_behind</name></joint>
        <joint><name>wheel_right_behind</name></joint> -->
        
        <!-- 腿部关节 -->
        <joint><name>knee_joint</name></joint>
        <joint><name>leg_joint</name></joint>
        <joint><name>waist_pitch_joint</name></joint>
        <joint><name>waist_yaw_joint</name></joint>
        
        <!-- 左臂关节 -->
        <joint><name>zarm_l1_joint</name></joint>
        <joint><name>zarm_l2_joint</name></joint>
        <joint><name>zarm_l3_joint</name></joint>
        <joint><name>zarm_l4_joint</name></joint>
        <joint><name>zarm_l5_joint</name></joint>
        <joint><name>zarm_l6_joint</name></joint>
        <joint><name>zarm_l7_joint</name></joint>
        
        <!-- 右臂关节 -->
        <joint><name>zarm_r1_joint</name></joint>
        <joint><name>zarm_r2_joint</name></joint>
        <joint><name>zarm_r3_joint</name></joint>
        <joint><name>zarm_r4_joint</name></joint>
        <joint><name>zarm_r5_joint</name></joint>
        <joint><name>zarm_r6_joint</name></joint>
        <joint><name>zarm_r7_joint</name></joint>
        
        <!-- 头部关节 -->
        <joint><name>zhead_1_joint</name></joint>
        <joint><name>zhead_2_joint</name></joint>
      </joints>

      </plugin>
  </gazebo>

</robot>
