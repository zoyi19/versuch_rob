        <joint><name>zarm_l4_joint</name></joint>
        <joint><name>zarm_l5_joint</name></joint>
        <joint><name>zarm_l6_joint</name></joint>
        <joint><name>zarm_l7_joint</name></joint>
        
        <!-- 右臂关节 -->
