  <!-- 仿真插件 -->
  <gazebo>
    <plugin name="gazebo_shm_interface" filename="libgazebo_sim_shm_interface.so">
      <!-- IMU配置 gazebo中fixed连接的link都只能获取第一个-->
      <imu>
        <frame_id>dummy_link</frame_id>
      </imu>
      
      <!-- 关节配置 -->
      <joints>
        <!-- 左腿关节 -->
        <joint><name>leg_l1_joint</name></joint>
        <joint><name>leg_l2_joint</name></joint>
        <joint><name>leg_l3_joint</name></joint>
        <joint><name>leg_l4_joint</name></joint>
        <joint><name>leg_l5_joint</name></joint>
        <joint><name>leg_l6_joint</name></joint>
        
        <!-- 右腿关节 -->
        <joint><name>leg_r1_joint</name></joint>
        <joint><name>leg_r2_joint</name></joint>
        <joint><name>leg_r3_joint</name></joint>
        <joint><name>leg_r4_joint</name></joint>
        <joint><name>leg_r5_joint</name></joint>
        <joint><name>leg_r6_joint</name></joint>
        
        <!-- 左臂关节 -->
        <joint><name>zarm_l1_joint</name></joint>
