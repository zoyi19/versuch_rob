      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <!-- 崎岖地形高度场纹理 -->
    <!-- size = (radius_x, radius_y, elevation_z, base_z) -->
    <hfield name="rough" file="../../mujoco_assets/rough.png" size="10 10 0.1 0.20"/>
  </asset>

  <worldbody>
    <light pos="0 0 3.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
        
    <!-- 斜坡元素 -->
    <geom name="slope"
      type="box"
      size="2.0 6.0 0.1"
      euler="0 -0.174533 0"
      pos="14 0 0.2571"
      rgba="0.7 0.7 0.7 1"/>
    <geom name="platform_10deg"
      type="box"
      size="0.5 6.0 0.08"
      euler="0 0 0"
      pos="16.46788 0 0.62288"
      rgba="0.6 0.6 0.6 1"/>

    <geom name="slope_down_10deg"
      type="box"
      size="2.0 6 0.1"
      euler="0 0.174533 0"
      pos="18.93576 0 0.25710"
      rgba="0.7 0.7 0.7 1"/>

    <geom name="slope_5deg"
      type="box"
      size="2.0 6 0.08"
      euler="0 -0.0872665 0"
      pos="3 0 0.08427"
      rgba="0.7 0.7 0.7 1"/>
    <geom name="platform_5deg"
      type="box"
      size="0.5 6 0.08"
      euler="0 0 0"
      pos="5.49152 0 0.25828"
      rgba="0.6 0.6 0.6 1"/>

    <geom name="slope_down_5deg"
