    (3,0)  0.0  ; z_arm_l3
    (4,0)  0.0  ; z_arm_l4
    (5,0)  0.0  ; z_arm_l5
    (6,0)  0.0  ; z_arm_l6
    (7,0)  0.0  ; z_arm_l7
    (8,0)  0.0  ; z_arm_r1
    (9,0)  0.0  ; z_arm_r2
    (10,0) 0.0  ; z_arm_r3
    (11,0) 0.0  ; z_arm_r4
    (12,0) 0.0  ; z_arm_r5
    (13,0) 0.0  ; z_arm_r6
    (14,0) 0.0  ; z_arm_r7
  }
}

stateCost
{
  ; control weight matrix
  Q
  {
    ; state costs for the different types of arm base DOFs
    base
    {
      defaultManipulator
      {
      }

      floatingArmManipulator
      {
        scaling 1e1

        (0,0)  500.0  ; position x
        (1,1)  500.0  ; position y
        (2,2)  500.0  ; position z
        (3,3)  500.0  ; euler angle z
        (4,4)  500.0  ; euler angle y
        (5,5)  500.0  ; euler angle x
      }

      fullyActuatedFloatingArmManipulator
      {
        scaling 1e-2

        (0,0)  5.0  ; position x
        (1,1)  5.0  ; position y
        (2,2)  300.0  ; position z (increased to reduce squatting)
        (3,3)  5.0  ; euler angle z
        (4,4)  200.0  ; euler angle y
        (5,5)  5.0  ; euler angle x
      }

      wheelBasedMobileManipulator
      {
        scaling 1e-2

        (0,0)  5.0  ; position x
        (1,1)  5.0  ; position y
        (2,2)  5.0  ; euler angle z
      }

      actuatedXYZYawPitchManipulator
      {
        scaling 1e-2

        (0,0)  5.0  ; position x
        (1,1)  5.0  ; position y
        (2,2)  5.0  ; position z
        (3,3)  5.0  ; euler angle z
        (4,4)  5.0  ; euler angle y
      }

      actuatedZPitchManipulator
      {
        scaling 1e-2

        (0,0)  5.0  ; position x
        (1,1)  5.0  ; position y
        (2,2)  5.0  ; position z
        (3,3)  5.0  ; euler angle z
        (4,4)  5.0  ; euler angle y
        (5,5)  5.0  ; euler angle x
      }
    }
  }
  Q_regularization
  {
    scaling 1e-2

    (6,6) 0.1 ; waist_yaw
    (7,7) 1.0 ; z_arm_l1
    (8,8) 10.0 ; z_arm_l2
    (9,9) 1.0 ; z_arm_l3
    (10,10) 1.0 ; z_arm_l4
    (11,11) 1.0 ; z_arm_l5
    (12,12) 1.0 ; z_arm_l6
    (13,13) 1.0 ; z_arm_l7
    (14,14) 1.0 ; z_arm_r1
    (15,15) 10.0 ; z_arm_r2
    (16,16) 1.0 ; z_arm_r3
    (17,17) 1.0 ; z_arm_r4
    (18,18) 1.0 ; z_arm_r5
    (19,19) 1.0 ; z_arm_r6
    (20,20) 1.0 ; z_arm_r7


  }
}

inputCost
