<?xml version="1.0" ?>

<launch>
    <!-- 输出日志格式 -->
    <env name="ROSCONSOLE_FORMAT" value="[${severity} ][${time:%Y-%m-%d-%H:%M:%S}][${node}]: ${message}"/>

    <!-- 基础参数 -->
    <arg name="output_system_info" default="true"/>
    <arg name="robot_type" default="1"/>    <!-- 1表示轮臂，2表示双足 -->
    <arg name="nodelet_robot_type" default="1"/>    <!-- 1表示轮臂，2表示双足 -->
    <arg name="wheel_control_type" default="1"/>    <!-- 0表示轮臂的仿真测试版mpc，1表示实际部署mpc -->
    <arg name="robot_version" default="$(optenv ROBOT_VERSION 40)"/>
    <arg name="rviz" default="true" />
    <arg name="multiplot" default="false"/>
    <arg name="use_shm_communication" value="true"/>

    <!-- 配置文件路径 -->
    <arg name="urdfFile" value="$(find kuavo_assets)/models/biped_s$(arg robot_version)/urdf/biped_s$(arg robot_version).urdf"/>
    <arg name="taskFile" value="$(find humanoid_wheel_interface)/config/kuavo_s$(arg robot_version)/task.info" />
    <arg name="libFolder"   value="/var/ocs2/kuavo_s$(arg robot_version)" />
    <param name="gaitCommandFile" value="$(find humanoid_controllers)/config/kuavo_v45/command/gait.info"/>
    <param name="referenceFile" value="$(find humanoid_controllers)/config/kuavo_v45/command/reference.info"/>

    <!-- MPC相关参数 -->
    <arg name="use_external_mpc" default="true"/>
    <arg name="use_sqp" default="true" doc="Use SQP if true, DDP if false"/>
    <arg name="wbc_frequency" default="500"/>
    <arg name="wbc_only" default="false"/>

    <!-- 控制相关参数 -->
    <arg name="sensor_frequency" default="500"/>
    <arg name="use_joystick" default="true"/>
    <arg name="joystick_type" default="sim"/>
    <arg name="arm_move_spd" default="1.2"/>
    <arg name="start_way" default="manual"/>

    <!-- 状态估计相关参数 -->
    <arg name="with_estimation" default="true"/>
    <arg name="use_joint_filter" default="false"/>
    <arg name="estimator_type" default="1"/>
    <arg name="use_estimator_contact" default="false"/>

    <!-- 其他功能参数 -->
    <arg name="play_back" default="false"/>
    <arg name="with_ik" default="true"/>
    <arg name="coredump" default="false"/>
    <arg name="with_coredump" value="--with-coredump" if="$(arg coredump)"/>
    <arg name="with_coredump" value="" unless="$(arg coredump)"/>
    <arg name="use_grab_box_scene" default="true"/>

    <!-- 加载机器人版本管理器 -->
    <include file="$(find humanoid_controllers)/launch/robot_version_manager.launch">
        <arg name="robot_version" value="$(arg robot_version)"/>
        <arg name="rviz" value="$(arg rviz)"/>
        <arg name="rvizconfig" default="$(find humanoid_wheel_interface_ros)/rviz/mobile_manipulator.rviz"/>
    </include>

    <!-- 参数设置 -->
    <param name="wbc_only" value="$(arg wbc_only)"/>
    <param name="use_external_mpc" value="$(arg use_external_mpc)"/>
    <param name="wbc_frequency" value="$(arg wbc_frequency)"/>
    <param name="sensor_frequency" value="$(arg sensor_frequency)"/>
    <param name="with_estimation" value="$(arg with_estimation)"/>
    <param name="use_joint_filter" value="$(arg use_joint_filter)"/>
    <param name="estimator_type" value="$(arg estimator_type)"/>
    <param name="play_back" value="$(arg play_back)"/>
    <param name="use_estimator_contact" value="$(arg use_estimator_contact)"/>
    <param name="use_shm_communication" value="$(arg use_shm_communication)"/>
    <param name="build_cppad_state" value="0"/>
    <param name="robot_type" value="$(arg robot_type)"/>
    <param name="nodelet_robot_type" value="$(arg nodelet_robot_type)"/>
    <param name="wheel_control_type" value="$(arg wheel_control_type)"/>
    <param name="taskFile" value="$(arg taskFile)" />
    <param name="urdfFile" value="$(arg urdfFile)" />
    <param name="libFolder"  value="$(arg libFolder)" />
    <param name="robot_description" textfile="$(arg urdfFile)"/>
    <rosparam param="isolated_cpus">[2, 3]</rosparam>

    <!-- 日志管理参数 -->
    <param name="/nodelet_manager/max_log_size_gb" value="64.0"/>
    <param name="/nodelet_manager/log_delete_limit_gb" value="60.0"/>

    <!-- 启动信息收集脚本 -->
    <node pkg="humanoid_controllers" type="collect_launch_info.sh" name="collect_launch_info" />

    <!-- MPC节点 -->
    <group if="$(arg use_sqp)">
        <node pkg="humanoid_wheel_interface_ros" type="mobile_manipulator_sqp_mpc_node" name="mobile_manipulator_sqp_mpc_node" 
            output="screen" launch-prefix="$(find humanoid_controllers)/scripts/start_node.sh $(arg with_coredump)"/>
    </group>
    <group unless="$(arg use_sqp)">
        <node pkg="humanoid_wheel_interface_ros" type="mobile_manipulator_mpc_node" name="mobile_manipulator_mpc_node" 
            output="screen" launch-prefix="$(find humanoid_controllers)/scripts/start_node.sh $(arg with_coredump)"/>
    </group>

    <!-- 目标控制节点 -->
    <node pkg="humanoid_wheel_interface_ros" type="mobile_manipulator_target" name="mobile_manipulator_target" 
        output="screen"/>

    <!-- Nodelet管理器和控制器 -->
    <node pkg="nodelet" type="nodelet" name="nodelet_manager" args="manager" respawn="false" 
        output="screen" required="true" clear_params="true"
        launch-prefix="$(find humanoid_controllers)/scripts/start_node.sh $(arg with_coredump)">
        <param name="num_worker_threads" type="int" value="10" />
    </node>

    <node pkg="nodelet" type="nodelet" name="nodelet_controller" 
        args="load HumanoidControllerNodelet nodelet_manager" 
        respawn="false" output="screen" required="true"/>

    <node pkg="nodelet" type="nodelet" name="ekf_se" 
        args="load RobotLocalization/EkfNodelet nodelet_manager" 
        respawn="false" output="screen" required="true" 
        launch-prefix="taskset -c 12">
        <rosparam command="load" file="$(find humanoid_estimation)/params/ekf_template.yaml" />
    </node>

    <!-- Gazebo仿真 -->
    <group unless="$(arg play_back)">
        <include file="$(find gazebo_sim)/launch/gazebo-sim.launch">
          <arg name="use_grab_box_scene" value="$(arg use_grab_box_scene)"/>
          <arg name="world_name" value="$(find gazebo_sim)/worlds/grab_box.world"/>
        </include>
    </group>

    <!-- Rosbag记录 -->

    <include file="$(find humanoid_interface)/launch/rosbag_nodelet.launch"/>

    <!-- 手柄控制 -->
    <group if="$(arg use_joystick)">
      <group if="$(eval arg('joystick_type') == 'h12')">
        <include file="$(find humanoid_controllers)/launch/joy/joy_control_h12.launch">
          <arg name="start_way" value="$(arg start_way)"/>
        </include>
      </group>
      <group if="$(eval arg('joystick_type') == 'sim')">
        <include file="$(find humanoid_controllers)/launch/joy/joy_control_sim_lb.launch">
          <arg name="joystick_type" value="$(arg joystick_type)"/>
        </include>
      </group>
      <group if="$(eval arg('joystick_type') == 'bt2' or arg('joystick_type') == 'bt2pro')">
        <include file="$(find humanoid_controllers)/launch/joy/joy_control_bt.launch">
          <arg name="joystick_type" value="$(arg joystick_type)"/>
        </include>
        <node pkg="humanoid_wheel_interface_ros" type="mobile_manipulator_joy_command_node" name="mobile_manipulator_joy_command_node" output="screen"/>
      </group>
    </group>

    <!-- 系统状态发布 -->
    <group if="$(arg output_system_info)">
        <node pkg="humanoid_controllers" type="system_info_publisher.py" name="system_info_publisher"/>
    </group>

    <!-- 监控节点 -->
    <node pkg="kuavo_monitor" type="kuavo_monitor_node" name="kuavo_monitor_node" 
        launch-prefix="$(find humanoid_controllers)/scripts/start_node.sh $(arg with_coredump)"/>

    <!-- IK节点 -->
    <group if="$(arg with_ik)">
        <include file="$(find motion_capture_ik)/launch/ik_node.launch"/>
    </group>

    <!-- 启动apriltag_ros的连续检测节点 -->
    <include file="$(find apriltag_ros)/launch/continuous_detection.launch">
      <arg name="camera_name" value="/camera/color"/>
      <arg name="image_topic" value="image_raw"/>
    </include>

</launch>
