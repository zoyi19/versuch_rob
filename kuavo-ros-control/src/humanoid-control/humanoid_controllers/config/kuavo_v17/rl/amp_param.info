withArm            true   ; 是否使用手臂训练 0:不使用 1:使用
inferenceFrequency 50     ; 推理频率

actionScale        0.25    ; default
frameStack         1      ; 多长时间步的obs
numSingleObs       72      ; 单一时刻的obs的维度
cycleTime          1.0     ; 周期时间为0.64s
cycleTime_short    1.0     ; 高步频时的周期时间0.8s
switch_ratio       1.5     ; 步频切换对应的cmdVelLineX比例,超过1就不会切换
phase              0       ; 初始相位设置为0
episodeLength      0       ; 用于计算相位，每走一个step就加1
clipObservations   5000.0    ; 用于对输入进行clip
clipActions        5000.0    ; 用于对actions进行clip
