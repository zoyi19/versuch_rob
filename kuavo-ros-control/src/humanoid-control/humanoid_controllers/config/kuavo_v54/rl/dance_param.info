; Dance Controller Configuration File for kuavo_v52
; 舞蹈控制器配置文件 - 适用于kuavo_v52 (27关节：12腿+1腰+14手臂)

withArm                 true    ; 是否使用手臂 0:不使用 1:使用
inferenceFrequency      50      ; 推理频率（Hz），建议保持50Hz

actionScale             1.0     ; 全局动作缩放系数
frameStack              1       ; 帧堆叠数量（历史帧数）
numSingleObs            148     ; 单帧观测维度 (27*2 + 3 + 3 + 6 + 1 + 27 + 27 = 136)
clipObservations        5000.0  ; 观测裁剪限制
clipActions             5000.0  ; 动作裁剪限制

; Dance控制器特定参数
trajectoryCSVFile       new_dance_s54_0309_deploy.csv    ; 轨迹CSV文件（相对路径）
trajectoryTimeStep      0.02    ; 轨迹时间步长（秒），默认50Hz
holdFrameIndex          -2      ; 轨迹完成后保持的帧索引（-1表示最后一帧，>=0表示指定帧）
networkModelFile        /xtf_yun23_kuavo5_new_35000.onnx      ; 神经网络模型文件路径
residualAction          true

defaultBaseHeightControl    0.95 ; 站立时的基座高度 (v52为0.95m)
is_fall_down_controller     false ; 是否为倒地起身控制器
use_interploate_from_mpc    true  ; 从MPC切换到dance时使用插值过渡到默认姿态
use_dance_ruiwo_kpkd        false  ; 是否使用 Dance 专用 Ruiwo 手臂增益

