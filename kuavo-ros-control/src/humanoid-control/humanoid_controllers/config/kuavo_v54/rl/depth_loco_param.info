withArm            true   ; 是否使用手臂训练 0:不使用 1:使用
inferenceFrequency 50     ; 推理频率

actionScale        1  ; default
frameStack         5      ; 多长时间步的obs
numSingleObs       18528      ; 单一时刻的obs的维度
cycleTime          1.2     ; 周期时间为1.2s
leg_bias            0.5 ;          
stance_ratio        0.5 ;
cycleTime_short    1.0     ; 高步频时的周期时间0.8s
switch_ratio       1.5     ; 步频切换对应的cmdVelLineX比例,超过1就不会切换
phase              0       ; 初始相位设置为0
episodeLength      0       ; 用于计算相位，每走一个step就加1
clipObservations   10000.0    ; 用于对输入进行clip
clipActions        100.0    ; 用于对actions进行clip
use_jointcmd_filter false       ; 是否对输出使用关节指令滤波器 0:不使用 1:使用
use_external_arm_controller true ; 是否使用外部手臂控制器指令替代模型输出的手臂指令 0:不使用 1:使用
use_external_waist_controller false ; 是否使用外部腰部控制器指令替代模型输出的腰部指令 0:不使用 1:使用
use_interploate_from_mpc     false       ; 从MPC切换到这个模型时是使用插值还是直接切换 0:不使用 1:使用
use_default_motor_csp_kpkd       false  ; ECmaster的电机是否使用默认的kpkd(kuavo.json),还是当前info中定义的，motor_pdo_kp、motor_pdo_kd
use_amp_ruiwo_kpkd          true  ; 是否在 AMP 控制器中使用并切换 AMP 专用 Ruiwo 手臂增益(true/false)

networkModelFile          /model_34600_lab_signal_0313.onnx       ; 
commandData 
{
    inital
    {
        cmdVelLineX         0   ;
        cmdVelLineY         0   ;
        cmdVelLineZ         0   ;
        cmdVelAngularX      0   ;
        cmdVelAngularY      0   ;
        cmdVelAngularZ      0   ;
        cmdStance           1   ;
    }
    scale
    {
        ; cmd_vel的倍率
        cmdVelLineX         1   ; 输入模型的最大cmdVelLineX = scale[0] * velocityLimits[0]
        cmdVelLineY         1       ; 输入模型的最大cmdVelLineY = scale[1] * velocityLimits[1]
        cmdVelLineZ         1       ; 输入模型的最大cmdVelLineZ = scale[2] * velocityLimits[2]
        cmdVelAngularX      1   ;
        cmdVelAngularY      1   ;
        cmdVelAngularZ      1.    ; 输入模型的最大cmdVelAngularZ = scale[5] * velocityLimits[3]
        cmdStance           1   ;
    }
};预留完整的接口，当前只用到cmdVelLineX, cmdVelLineY, cmdVelAngularZ, cmdWalkEnable，最大长度是4

