Q_base_stance
{
    scaling 1e+0

  ;; Normalized Centroidal Momentum: [linear, angular] ;;
  (0,0)   13.0     ; vcom_x
  (1,1)   13.0     ; vcom_y
  (2,2)   13.0     ; vcom_z
  (3,3)   13.0      ; L_x / robotMass
  (4,4)   13.0     ; L_y / robotMass
  (5,5)   13.0     ; L_z / robotMass

  ;; Base Pose: [position, orientation] ;;
  (6,6)   500.0    ; p_base_x
  (7,7)   500.0    ; p_base_y
  (8,8)   800.0    ; p_base_z
  (9,9)   100.0    ; theta_base_z
  (10,10) 500.0    ; theta_base_y
  (11,11) 2000.0    ; theta_base_x

  ;; Leg Joint Positions: [knee, leg, waist_pitch, waist_yaw] ;;
  (12,12) 300.0     ; knee_joint
  (13,13) 300.0     ; leg_joint
  (14,14) 10.0      ; waist_pitch_joint
  (15,15) 10.0      ; waist_yaw_joint
}

